# Copiá a .env y completá. NO commitees el .env real.

# --- Postgres ---
POSTGRES_HOST=tu-host
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD="tu-password"
POSTGRES_DB=portfolio
# disable | no-verify | require
POSTGRES_SSL=disable

# --- Panel admin ---
# Los usuarios viven en la tabla `users` (login por cédula). Crear el
# primero con: pnpm user:create <cedula> "<nombres>" <password>
# SESSION_SECRET es la clave de firma de la cookie (NO es un usuario).
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=un-secret-aleatorio-largo
