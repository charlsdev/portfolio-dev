      "user:passwd": "tsx scripts/user-passwd.ts"
   },
   "devDependencies": {
      "@biomejs/biome": "^1.5.3",
      "@sveltejs/adapter-node": "^5.5.4",
      "@sveltejs/kit": "^2.60.1",
      "@sveltejs/vite-plugin-svelte": "^7.1.2",
      "@tailwindcss/vite": "^4.3.0",
      "@types/node": "^20.11.17",
      "dotenv": "^16.4.7",
      "drizzle-kit": "^0.31.10",
      "svelte": "^5.55.7",
      "svelte-check": "^4.4.8",
      "tailwindcss": "^4.3.0",
      "tslib": "^2.6.2",
      "tsx": "^4.19.2",
      "typescript": "^5.2.2",
      "vite": "^8.0.13"
   },
   "dependencies": {
      "@node-rs/argon2": "^2.0.2",
      "drizzle-orm": "^0.45.2",
      "postgres": "^3.4.9",
