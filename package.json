{
   "name": "portfolio-dev",
   "private": true,
   "version": "0.1.0",
   "type": "module",
   "packageManager": "pnpm@10.33.2",
   "scripts": {
      "dev": "vite dev --port 4000",
      "build": "vite build",
      "preview": "node --env-file-if-exists=.env build",
      "start": "node --env-file-if-exists=.env build",
